# Copy this file to .env and fill in real values before running locally.
# NEVER commit .env to source control.

# PostgreSQL password for the local database (docker-compose only).
# Use a strong, randomly generated value.
POSTGRES_PASSWORD=change-me-strong-password

# Secret key used by Langflow for session signing and encryption.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LANGFLOW_SECRET_KEY=change-me-secret-key
